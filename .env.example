# Copy to .env and fill in real values. .env is gitignored — never commit secrets.
POSTGRES_USER=pawdex
POSTGRES_PASSWORD=change-me
POSTGRES_DB=pawdex

# Comma-separated origins allowed to call the ML API (browser never calls it
# directly, but this keeps the allowlist explicit and environment-driven).
PAWDEX_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# YOLO detector configuration.
PAWDEX_YOLO_MODEL=yolo11n.pt
PAWDEX_YOLO_CONFIDENCE=0.35
