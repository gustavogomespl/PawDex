# Copy to .env and fill in real values. .env is gitignored — never commit secrets.
POSTGRES_USER=pawdex
POSTGRES_PASSWORD=change-me
POSTGRES_DB=pawdex

# Comma-separated origins allowed to call the ML API (browser never calls it
# directly, but this keeps the allowlist explicit and environment-driven).
PAWDEX_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# YOLO detector configuration.
PAWDEX_YOLO_MODEL=yolo11n.pt
PAWDEX_YOLO_CONFIDENCE=0.35

# Max analyze-sighting (inference) requests per user per minute.
PAWDEX_RATE_LIMIT_PER_MIN=60

# Auth.js (NextAuth) secret for signing JWT sessions. Generate with:
#   openssl rand -base64 32
AUTH_SECRET=change-me-generate-a-random-32-byte-secret
# Enable the passwordless development e-mail provider. Keep false in production
# unless this stack is isolated for local/demo use only.
PAWDEX_ENABLE_DEV_AUTH=true

# Shared secret the Next.js server sends to the ML API (X-Internal-Token). When
# set, the ML API only trusts callers presenting it. Leave unset locally to skip.
PAWDEX_INTERNAL_TOKEN=change-me-internal-token

# Object storage (MinIO/S3) for cropped photos. Endpoint/bucket default to the
# compose MinIO service; set credentials here. Railway Buckets can also use
# AWS_ENDPOINT_URL, AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY, AWS_S3_BUCKET_NAME.
PAWDEX_S3_ACCESS_KEY=pawdex
PAWDEX_S3_SECRET_KEY=change-me-minio-secret
PAWDEX_S3_BUCKET=pawdex
# PAWDEX_S3_ENDPOINT=minio:9000
# PAWDEX_S3_SECURE=false
